# ── OPENROUTER (DeepSeek for captions) ──────────────────────────
OPENROUTER_API_KEY=your_openrouter_key_here

# ── TELEGRAM ─────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=your_bot_token_here
TELEGRAM_CHAT_ID=7477833460

# ── YOUTUBE ──────────────────────────────────────────────────────
YOUTUBE_CLIENT_ID=your_google_client_id
YOUTUBE_CLIENT_SECRET=your_google_client_secret
YOUTUBE_REDIRECT_URI=https://your-railway-url.railway.app/auth/youtube/callback
YOUTUBE_REFRESH_TOKEN=your_refresh_token

# ── X / TWITTER ──────────────────────────────────────────────────
TWITTER_API_KEY=your_api_key
TWITTER_API_SECRET=your_api_secret
TWITTER_ACCESS_TOKEN=your_access_token
TWITTER_ACCESS_SECRET=your_access_secret

# ── PINTEREST ─────────────────────────────────────────────────────
PINTEREST_ACCESS_TOKEN=your_pinterest_token
PINTEREST_BOARD_ID=your_board_id

# ── FACEBOOK / INSTAGRAM ─────────────────────────────────────────
META_PAGE_ID=your_facebook_page_id
META_IG_USER_ID=your_instagram_user_id
META_ACCESS_TOKEN=your_long_lived_page_token

# ── TIKTOK ───────────────────────────────────────────────────────
TIKTOK_CLIENT_KEY=your_tiktok_client_key
TIKTOK_CLIENT_SECRET=your_tiktok_client_secret
TIKTOK_ACCESS_TOKEN=your_tiktok_access_token

# ── APP ───────────────────────────────────────────────────────────
PORT=3000
MEDIA_DIR=/data/media-queue
DB_PATH=/data/autoposter.db
FRONTEND_URL=https://your-netlify-site.netlify.app
